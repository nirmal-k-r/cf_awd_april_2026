<%- include('../../partials/header.ejs') %>

<section>
    <div class="container">
        <% if (user) { %>
            <div class="alert alert-success text-center col-md-6 mx-auto" role="alert">
                Welcome to Shopmaster <%= user.name %>
            </div>
        <% } %> 

        <br>
        <div class="col-md-8 mx-auto">
            <form class="d-flex" role="search">
                <div class="row mx-auto">
                    <div class="col-md-10">
                        <input class="form-control me-2" type="search" name="keyword" id="keyword" placeholder="Search for products..." onkeydown="showSuggestions()" aria-label="Search">
                        <div class="suggestionBox">
                        <!-- Search suggestions will be displayed here -->

                        </div>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-success" type="submit">Search</button>
                    </div>
                </div>
                
                
            </form>
            
        </div>
        
    </div>
</section>
<br><br>

<section>
    <div class="container mx-auto">
        <div class="row mx-auto text-center">
            <% products.forEach(product => { %>
                <div class="col-md-3 mb-5">
                    <div class="card">
                        <a href="/product/<%= product._id %>">
                            <img class="card-img-top" src="<%= product.image %>" alt="Card image cap">
                        </a>
                        <div class="card-body text-center">
                            <h5 class="card-title">
                                <a href="/product/<%= product._id %>" class="no-text-decoration"><%= product.name %></a>
                            </h5>
                            <p class="card-text"><%= product.category %></p>
                        </div>
                        
                        <div class="card-body text-center">
                            <p class="card-textn fw-bold"> Rs <%= product.price %></p>
                            <button class="btn btn-primary text-center text-light" onclick="addToCart('<%= product._id %>')">Add to cart</button>
                        </div>
                    </div>

                </div>

            <% }) %>
               
    </div>
</section>


        
<%- include('../../partials/footer.ejs') %> 


<script>
    function showSuggestions() {
        const keyword = document.getElementById('keyword').value;
        if (keyword.length > 0) {
            fetch(`/searchSuggestions?keyword=${keyword}`)
                .then(response => response.json())
                .then(data => {
                    // Handle the search suggestions here
                    displaySuggestions(data);
                })
                .catch(error => {
                    console.error('Error fetching search suggestions:', error);
                });
        }
    }

    function displaySuggestions(suggestions) {
        const suggestionBox = document.querySelector('.suggestionBox');
        suggestionBox.innerHTML = ''; // Clear previous suggestions

        suggestions.forEach(suggestion => {
            const suggestionItem = document.createElement('div');
            suggestionItem.classList.add('suggestionItem');
            anchorElement = document.createElement('a');
            anchorElement.textContent = suggestion.name;
            anchorElement.classList.add('no-text-decoration');
            anchorElement.href = suggestion.link; 
            suggestionItem.appendChild(anchorElement);
            suggestionBox.appendChild(suggestionItem);
        });
    }

    function addToCart(productId) {
        fetch(`/addToCart?productId=${productId}&quantity=1`)
        .then(response => response.json())
        .then(data => {
            if (data.message=="success") {
                alert('Product added to cart successfully!');
            } else {
                alert('Failed to add product to cart.');
            }
        })
        .catch(error => {
            console.error('Error adding product to cart:', error);
            alert('An error occurred while adding the product to the cart.');
        });
    }
</script>
