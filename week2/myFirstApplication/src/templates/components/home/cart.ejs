<%- include('../../partials/header.ejs') %>


<section>
    <div class="container">
        <% if (Object.keys(cart).length === 0) { %>
            <div class="alert alert-info text-center" role="alert">
                Your cart is empty. Start shopping now!
            </div>
        <% }else{ %> 
            <div class="container">
                <div class="alert alert-success mx-auto text-center" role="alert">
                    Review your cart
                </div>
            </div>
            <div class="container mx-auto text-center">
                <% cartDetails.forEach(item => { %>
                    <div class="row text-center mb-4 mx-auto">
                            <div class="col-md-2">
                                <img src="<%= item.product.image %>" class="img-fluid rounded-start dash-img" alt="Product Image" style="max-height: 100px;">
                            </div>

                             <div class="col-md-2 align-middle justify-content-center d-flex align-items-center">
                                <a><%= item.product.name %></a>
                             </div>
                            
                             <div class="col-md-2 align-middle justify-content-center d-flex align-items-center">
                                 <input type="number" class="form-control" style="width:200px" id="quantity" value="<%= item.quantity %>" min="1" onchange="updateCart('<%= item.product._id %>', this.value)">
                             </div>

                             <div class="col-md-2 align-middle justify-content-center d-flex align-items-center">
                                 <a id="price_<%= item.product._id %>">Rs <%= item.product.price %></a>
                             </div>

                             <div class="col-md-2 align-middle justify-content-center d-flex align-items-center">
                                 <a id="total_<%= item.product._id %>">Rs <%= item.product.price * item.quantity %> </a>
                             </div>
                            
                            <div class="col-md-2 align-middle justify-content-center d-flex align-items-center">
                                <a href="/delete-from-cart?productId=<%= item.product._id %>" class="btn btn-danger">Remove</a>
                            </div>
                    </div>
                <% }) %>
                <div class="row text-center mb-4 mx-auto">
                    <div class="col-md-12 align-middle justify-content-center d-flex align-items-center">
                        <h3 id="cartTotal" class="mr-3">Total Price: </h3>
                        <button type="button" class="btn btn-primary ml-3" data-bs-toggle="modal" data-bs-target="#confirmModal">Checkout</button>
                        
                    </div>
                </div>  
            </div>
        <% } %>
        
        <div class="modal" tabindex="-1" id="confirmModal">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirmation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to checkout?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <a href="/checkout" class="btn btn-primary">Checkout</a>
                    </div>
                </div>
            </div>
        </div>

       


    </div>

    <script>
        function updateCart(productId, quantity){
            fetch('/update-cart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ productId, quantity })
            })
            .then(response => response.json())
            .then(data => {
                if (data.message == 'success') {
                   totalPrice = data.totalPrice;
                   document.getElementById('total_' + productId).innerText = 'Rs ' + totalPrice;
                   getCartTotal();
                }
            })
            .catch(error => console.error('Error:', error));
        }
        
        function getCartTotal(){
            fetch('/cartTotal')
            .then(response => response.json())
            .then(data => {
                if (data.message == 'success') {
                    if (document.getElementById('cartTotal')){
                         document.getElementById('cartTotal').innerText = 'Total Price: Rs ' + data.totalPrice;
                    }
                }
            })
            .catch(error => console.error('Error:', error));
        }

        getCartTotal();  

    </script>
   
</section> 
<%- include('../../partials/footer.ejs') %> 